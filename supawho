#!/bin/bash
# supawho - Manage multiple Supabase accounts securely via macOS Keychain
#
# Usage:
#   supawho              → Interactive account selection + login
#   supawho add <name> <token>  → Save account token to Keychain
#   supawho remove <name>       → Remove account from Keychain
#   supawho list                → List saved accounts
#   supawho use <name>          → Login with specific account
#
# Install globally:
#   cp supawho /usr/local/bin/ && chmod +x /usr/local/bin/supawho

VERSION="1.2.0"

show_banner() {
  local green=$'\033[1;32m'
  local reset=$'\033[0m'
  echo ""
  printf '%s%s%s\n' "$green" '   ___  _   _ ___  ___  _    _ _  _  ___' "$reset"
  printf '%s%s%s\n' "$green" '  / __|| | | | _ \/ _ \| |  | | || |/ _ \' "$reset"
  printf '%s%s%s\n' "$green" '  \__ \| |_| |  _/ (_) | |/\| | __ | (_)' "$reset"
  printf '%s%s%s\n' "$green" '  |___/ \___/|_|  \__\_\__/\__|_||_|\___/' "$reset"
  echo ""
  echo "     🔍 Who are you today?"
  echo ""
}

KEYCHAIN_SERVICE="supabase-cli-accounts"
KEYCHAIN_INDEX_KEY="_account_list"

# --- Helpers ---

get_account_list() {
  local list
  list=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_INDEX_KEY" -w 2>/dev/null)
  echo "$list"
}

save_account_list() {
  local list="$1"
  # Delete old entry if exists
  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_INDEX_KEY" 2>/dev/null
  security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_INDEX_KEY" -w "$list"
}

get_token() {
  local name="$1"
  security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$name" -w 2>/dev/null
}

# --- Commands ---

cmd_guided_add() {
  echo "  No accounts found. Let's add your first one!"
  echo ""
  echo "  Get your token here:"
  echo "  → https://supabase.com/dashboard/account/tokens"
  echo ""
  read -rp "  Account name (e.g. myproject): " name
  if [[ -z "$name" ]]; then
    echo "  Aborted."
    exit 1
  fi
  read -rp "  Access token (sbp_...): " token
  if [[ -z "$token" ]]; then
    echo "  Aborted."
    exit 1
  fi
  echo ""
  cmd_add "$name" "$token"
  echo ""
  read -rp "  Login now as '$name'? [Y/n] " confirm
  if [[ -z "$confirm" || "$confirm" =~ ^[Yy]$ ]]; then
    cmd_use "$name"
  fi
}

cmd_add() {
  local name="$1"
  local token="$2"

  if [[ -z "$name" || -z "$token" ]]; then
    show_banner
    cmd_guided_add
    exit 0
  fi

  # Save token to Keychain
  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$name" 2>/dev/null
  security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$name" -w "$token"

  # Update account list
  local list
  list=$(get_account_list)
  if [[ -z "$list" ]]; then
    list="$name"
  elif ! echo "$list" | tr ',' '\n' | grep -qx "$name"; then
    list="$list,$name"
  fi
  save_account_list "$list"

  echo "Account '$name' saved to Keychain."
}

cmd_remove() {
  local name="$1"

  if [[ -z "$name" ]]; then
    echo "Usage: supawho remove <name>"
    exit 1
  fi

  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$name" 2>/dev/null

  # Update account list
  local list
  list=$(get_account_list)
  list=$(echo "$list" | tr ',' '\n' | grep -vx "$name" | paste -sd ',' -)
  save_account_list "$list"

  echo "Account '$name' removed."
}

cmd_list() {
  local list
  list=$(get_account_list)

  if [[ -z "$list" ]]; then
    echo "No accounts saved. Add one with:"
    echo "  supawho add <name> <token>"
    exit 0
  fi

  echo "Saved accounts:"
  echo "$list" | tr ',' '\n' | while read -r name; do
    echo "  - $name"
  done
}

cmd_use() {
  local name="$1"

  if [[ -z "$name" ]]; then
    echo "Usage: supawho use <name>"
    exit 1
  fi

  local token
  token=$(get_token "$name")

  if [[ -z "$token" ]]; then
    echo "Account '$name' not found. Run 'supawho list' to see saved accounts."
    exit 1
  fi

  echo "Logging in as '$name'..."
  supabase login --token "$token"
  echo "Logged in as '$name'."
}

cmd_interactive() {
  local list
  list=$(get_account_list)

  show_banner

  if [[ -z "$list" ]]; then
    cmd_guided_add
    exit 0
  fi

  # Build array of account names
  local accounts=()
  IFS=',' read -ra accounts <<< "$list"

  echo "Select an account:"
  echo ""
  for i in "${!accounts[@]}"; do
    echo "  $((i + 1))) ${accounts[$i]}"
  done
  echo ""
  read -rp "Enter number (1-${#accounts[@]}): " choice

  if [[ -z "$choice" || "$choice" -lt 1 || "$choice" -gt "${#accounts[@]}" ]] 2>/dev/null; then
    echo "Invalid selection."
    exit 1
  fi

  local selected="${accounts[$((choice - 1))]}"
  cmd_use "$selected"
}

# --- Main ---

case "${1:-}" in
  add)
    cmd_add "$2" "$3"
    ;;
  remove)
    cmd_remove "$2"
    ;;
  list)
    cmd_list
    ;;
  use)
    cmd_use "$2"
    ;;
  version|--version|-v)
    echo "supawho ${VERSION}"
    ;;
  help|--help|-h)
    show_banner
    echo "Usage:"
    echo "  supawho                       Interactive account selection"
    echo "  supawho add <name> <token>     Save account to Keychain"
    echo "  supawho remove <name>          Remove account"
    echo "  supawho list                   List saved accounts"
    echo "  supawho use <name>             Login with specific account"
    echo "  supawho version                Show version"
    echo ""
    echo "Tokens are stored securely in macOS Keychain."
    ;;
  "")
    cmd_interactive
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'supawho help' for usage."
    exit 1
    ;;
esac
